NODE_ENV=development

# PostgreSQL
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=serve_os_db
POSTGRES_DB_SSL=false

# Migration overrides (optional — falls back to POSTGRES_* if unset)
MIGRATION_POSTGRES_HOST=localhost
MIGRATION_POSTGRES_PORT=5434

# App
PORT=4000
# Dev: http://localhost:3000  |  Production: https://serve-os.net
CORS_ORIGIN=http://localhost:3000
# Production: .serve-os.net — shares cookies across serve-os.net and api.serve-os.net
# Leave unset in dev (localhost doesn't need cross-subdomain sharing)
COOKIE_DOMAIN=

# Auth
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption
MASTER_ENCRYPTION_KEY=change-me-in-production

# S3-compatible object storage
# Local dev: MinIO (started via docker-compose.dev.yml)
# Production: set these to your Cloudflare R2 / Backblaze B2 / AWS S3 values
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=serve-os-dev
# Dev: http://localhost:9000/<bucket>  |  Production: https://storage.serve-os.net/<bucket>
S3_PUBLIC_URL=http://localhost:9000/serve-os-dev
